# SiYuan Note skill – local environment template
# Copy this file to `.env` in the skill root (next to SKILL.md).
# The script auto-loads `.env`; set SIYUAN_SKIP_DOTENV=1 to disable.
#
#   cp .env.example .env
#   # then edit .env and paste your real token
#
# Get the token from SiYuan desktop:
#   Settings → About → API token
#
# 思源笔记 skill 本地环境模板
# 复制本文件为 `.env`(与 SKILL.md 同级),脚本会自动加载;
# 临时禁用请设置 SIYUAN_SKIP_DOTENV=1。
#
#   cp .env.example .env
#   # 然后编辑 .env 填入真实 token
#
# 获取 token:思源桌面端 → 设置 → 关于 → API token

# Required / 必填:API token from SiYuan
SIYUAN_TOKEN=

# Optional / 选填:default http://127.0.0.1:6806
SIYUAN_URL=http://127.0.0.1:6806
